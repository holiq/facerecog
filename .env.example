# Database Configuration (Required)
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/facerecog
TABLE_NAME="face_entities"

# Server Configuration (Optional - these have defaults in Dockerfile)
PORT=8000
WORKERS=1
LOG_LEVEL=info

# Face Recognition Settings (Optional)
FACE_MATCH_THRESHOLD=0.35
FACE_MIN_IMAGE_SIZE=100
FACE_MAX_IMAGE_SIZE=2048
FACE_BLUR_THRESHOLD=50.0
FACE_BRIGHTNESS_MIN=40.0
FACE_BRIGHTNESS_MAX=210.0

# Models: buffalo_l, buffalo_m, buffalo_s
INSIGHTFACE_MODEL_NAME="buffalo_l"
INSIGHTFACE_DET_SIZE=640

# Cache Options: 'redis', 'memory', 'disabled'
CACHE_STRATEGY="memory"
REDIS_URL=
